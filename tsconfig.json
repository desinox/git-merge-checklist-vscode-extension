{
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"target": "ES2021",
		"lib": ["ES2021", "DOM", "DOM.Iterable"],
		"jsx": "react-jsx",
		"outDir": "dist",
		"sourceMap": true,
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"isolatedModules": true
	},
	"include": ["src", "webview"],
	"exclude": ["node_modules", "dist"]
}
